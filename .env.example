# =======================================================
# TogoMarket — Template d'environnement
# Copier ce fichier en .env et renseigner les valeurs
# =======================================================

# ── Environnement ────────────────────────────────────
APP_ENV=local
APP_DEBUG=true
APP_NAME=TogoMarket

# ── URL de base ──────────────────────────────────────
# local  : http://localhost/TogoMarket/TGO/
# prod   : https://ton-domaine.com/
BASE_URL=http://localhost/TogoMarket/TGO/

# ── Base de données ───────────────────────────────────
DB_HOST=localhost
DB_NAME=TG
DB_USER=root
DB_PASS=
DB_CHARSET=utf8mb4

# ── Analytics ─────────────────────────────────────────
ANALYTICS_ID=
